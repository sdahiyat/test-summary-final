# ============================================================
# edtNutriTrack — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/public key (safe to expose to the browser; enforced by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role key — SERVER-SIDE ONLY, bypasses RLS.
# NEVER expose this to the client or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── OpenAI ────────────────────────────────────────────────────
# Find this at: https://platform.openai.com/api-keys
# Used for AI-powered food photo recognition.
OPENAI_API_KEY=<your-openai-api-key>

# ── NextAuth ──────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=<random-32-char-string>

# The canonical URL of your app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
