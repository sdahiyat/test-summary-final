# ============================================================
# edtNutriTrack — Local Environment Variables
# Copy this file and fill in real values from your Supabase project.
# This file is NOT committed to version control.
# See .env.example for documentation of each variable.
# ============================================================

# Supabase (find these in: Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI (find this at: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
